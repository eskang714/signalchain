# ===========================
# Signal Chain - .gitignore
# Base: GitHub official Python template
# Extended for Signal Chain specifics
# ===========================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# uv (package manager)
.uv/

# Testing
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Linting
.ruff_cache/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# IDEs
# VS Code - keep extensions.json, ignore personal settings
.vscode/*
!.vscode/extensions.json
.history/

# PyCharm
.idea/

# Jupyter
.ipynb_checkpoints
*.ipynb

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment variables - never commit
.env
.env.local
.env.*.local

# ===========================
# Signal Chain Specific
# ===========================

# User data - stays on user's device, never in repo
*.gguf                          # Local model files (can be 40GB+)
models/                         # Downloaded model directories

# Application user data
signal_chain_data/
conversations/
outputs/
cache/

# OS keychain backups (credentials)
*.keychain
*.keychain-db

# Logs
*.log
logs/

# Compiled UI files (PyQt6 generates these)
*.pyc
ui_*.py                         # Auto-generated from .ui files

# Distribution builds
*.dmg                           # macOS installer
*.exe                           # Windows installer
*.deb                           # Linux package
*.rpm                           # Linux package
*.AppImage                      # Linux AppImage

# Secrets - hard rule, never commit
*secret*
*credential*
*api_key*
*.pem
*.key

# Personal operational files (not for repo)
personal/

# Claude Code local data
.claude/
